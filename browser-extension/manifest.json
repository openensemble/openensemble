{
  "manifest_version": 3,
  "name": "OpenEnsemble Bridge",
  "short_name": "OE Bridge",
  "version": "0.4.0",
  "description": "Chat with your OpenEnsemble server about the web. OE can only see or act on a tab after you grant a short, origin-bound, visible, revocable access lease.",
  "permissions": ["tabs", "storage", "scripting", "activeTab", "alarms", "sidePanel"],
  "side_panel": { "default_path": "sidepanel.html" },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/oe-bridge-16.png",
    "32": "icons/oe-bridge-32.png",
    "48": "icons/oe-bridge-48.png",
    "128": "icons/oe-bridge-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-banner.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-observe.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OpenEnsemble Bridge",
    "default_icon": {
      "16": "icons/oe-bridge-16.png",
      "32": "icons/oe-bridge-32.png",
      "48": "icons/oe-bridge-48.png",
      "128": "icons/oe-bridge-128.png"
    }
  }
}
