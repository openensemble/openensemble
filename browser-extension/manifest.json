{
  "manifest_version": 3,
  "name": "OpenEnsemble Bridge",
  "short_name": "OE Bridge",
  "version": "0.1.0",
  "description": "Lets your OpenEnsemble server read and open tabs in your local browser. Phase 1 — read-only, LAN-only.",
  "permissions": ["tabs", "storage", "scripting", "activeTab", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-banner.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OpenEnsemble Bridge"
  }
}
