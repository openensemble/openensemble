# ============================================================
# OpenEnsemble .gitignore
# Protects personal data, credentials, and runtime state.
# If a new runtime path appears, add it here BEFORE committing.
# ============================================================

# --- Credentials & config ---
config.json
gmail-credentials.json
*.pem
*.key
.env
.env.*

# --- oe-admin per-install state (never commit) ---
/config/user-providers.json
/config/oe-admin-audit.jsonl
/config/oe-admin-audit-archive-*.jsonl
/config/oe-admin-snapshots/
/config/.pending-change.json

# --- Per-user data (anchored to repo root) ---
/users/
/sessions/
/sharing.json
/shared-notes.json
/shared-docs/
/messages.json
/threads.json
/active-sessions.json
/nodes.json
/invites.json
/MCP_TODO.md

# --- User-generated content (anchored to repo root) ---
/expenses/
/tasks/
/research/
/images/
/videos/
/activity/
/agents/

# --- Vector DBs & ML artifacts ---
cortex-lancedb/
memory-db/
lancedb/
training-data/
training/
models/
vendor/
!public/vendor/
unsloth_compiled_cache/
venv/
runtime/

# --- Claude session scratch ---
.claude-revert-log-*.md
*.safetensors
*.ckpt
*.gguf
*.onnx

# --- User-installed plugins (keep only default markets/news) ---
plugins/*
!plugins/markets/
!plugins/news/

# --- Developer tools (scripts with local auth paths) ---
tools/
scripts/probe-oauth-models.mjs
scripts/test-parse-endpoint.mjs
scripts/test-miltime-*.mjs
scripts/test-task-creation.mjs
scripts/chat-smoke.mjs
scripts/smoke-plan-*.mjs

# --- Local tests ---
/tests/

# --- Local handoff/scratch notes (never for the public repo) ---
*_HANDOFF.md
/handoffs/

# --- Runtime artifacts ---
server.pid
tunnel.json
tunnel.pid
/bin/

# --- Logs ---
*.log
server.log
/logs/

# --- Scratch skill dirs ---
skills/temp/

# --- Build artifacts ---
public/styles.css

# --- Installer-generated (path-baked, varies per install dir) ---
/start.sh

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE / OS ---
.claude/
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~
*.bak
*.orig

# --- Scheduled task state ---
scheduled_tasks.lock

# --- Backup/restore owner state (per-install, not code) ---
.backup-meta/

# --- Design / working notes (not for public repo) ---
SCHEDULER_V2_CHANGES.md
*_CHANGES.md
*_NOTES.md
CLAUDE.md
scripts/*.failures.jsonl

# --- Local revert references (not for public repo) ---
REVERT_*.md
REVERT_*.patch
revert-*.md
revert-*.patch
MIGRATION_per-user-encryption.md

# Browser extension — kept out of the repo until fully developed (see commit msg)
/browser-extension/

# voice-device wake-capture audio (per-device personal recordings)
wake-captures/
# dated firmware/source backups (foo.bak-0.2.xx)
*.bak-*
