# Keep private installation state out of Docker build layers and registries.
# Dockerfile uses COPY . ., so this list intentionally mirrors the sensitive
# and runtime-only portions of .gitignore.

# Source-control and local tooling
.git/
**/.git/
.github/
.claude/
.vscode/
.idea/
.DS_Store
**/.DS_Store
node_modules/
**/node_modules/
**/__pycache__/
**/*.pyc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tests/
handoffs/
grok/
tools/
*.test.mjs
*.test.js
*.swp
*.swo
*~

# Credentials and machine-local configuration
.env
.env.*
**/.env
**/.env.*
*.pem
*.key
**/*.pem
**/*.key
/tls/
/config.json
/gmail-credentials.json
/microsoft-credentials.json
/gcal-token.json
/gmail-token.json
/email-accounts-user_*.json
/gmail-autolabel-user_*.json
/gcal-token-user_*.json
/gmail-token-user_*.json
/ms-token-user_*.json
/shared-notes-user_*.json
/cortex-user_*/
/avatars/
/config/user-providers.json
/config/oe-admin-audit.jsonl
/config/oe-admin-audit-archive-*.jsonl
/config/oe-admin-snapshots/
/config/.pending-change.json

# User data, auth state, and runtime registries
/users/
/sessions/
/sharing.json
/shared-notes.json
/shared-docs/
/messages.json
/threads.json
/active-sessions.json
/background-task-journal.json
/mcp-access-tokens.json
/browser-pairing.json
/nodes.json
/admission-requests.json
/mdns-instance.json
/dep-status.json
/last-dep-install.log
/invites.json
/MCP_TODO.md
/expenses/
/tasks/
/research/
/images/
/videos/
/activity/
/agents/

# Generated models, databases, recordings, and other large runtime artifacts
cortex-lancedb/
memory-db/
lancedb/
training-data/
training/
models/
/vendor/
unsloth_compiled_cache/
venv/
runtime/
*.safetensors
*.ckpt
*.gguf
*.onnx
wake-captures/
wake-captures-manual/
tv-app/
.backup-meta/
backups/
*.bak-*
**/*.bak-*
**/*.bak
**/*.orig

# Only the two bundled plugins belong in a distributable image.
plugins/*
!plugins/markets/
!plugins/markets/**
!plugins/news/
!plugins/news/**

# Logs, process state, and local/generated output
*.log
**/*.log
/logs/
/server.pid
/tunnel.json
/tunnel.pid
/bin/
/scheduled_tasks.lock
/public/styles.css
/start.sh
/docker-data/
skills/temp/
scripts/*.failures.jsonl
*_HANDOFF.md
*_CHANGES.md
*_NOTES.md
CLAUDE.md
.claude-revert-log-*.md
REVERT_*.md
REVERT_*.patch
revert-*.md
revert-*.patch
MIGRATION_per-user-encryption.md

# Local scripts intentionally excluded by .gitignore.
scripts/probe-oauth-models.mjs
scripts/test-parse-endpoint.mjs
scripts/test-miltime-*.mjs
scripts/test-task-creation.mjs
scripts/chat-smoke.mjs
scripts/smoke-plan-*.mjs
